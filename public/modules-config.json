      },
      {
        "key": "lang",
        "label": "Idioma",
        "type": "select",
        "required": false,
        "default": "ca",
        "options": ["ca", "en", "es"]
      },
      {
        "key": "updateInterval",
        "label": "Interval d'actualització (ms)",
        "type": "number",
        "required": false,
        "default": 3600000
      }
    ]
  },
