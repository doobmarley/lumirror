{
  "MMM-WiFiPassword": {
    "fields": [
      {
        "key": "network",
        "label": "Nom de la xarxa WiFi (SSID)",
        "type": "text",
        "required": true,
        "placeholder": "El meu WiFi"
      },
      {
        "key": "password",
        "label": "Contrasenya",
        "type": "password",
        "required": true,
        "placeholder": "La meva contrasenya"
      },
      {
        "key": "authType",
        "label": "Tipus d'autenticació",
        "type": "select",
        "required": false,
        "default": "WPA",
        "options": ["WPA", "WEP", "NONE"]
      },
      {
        "key": "header",
        "label": "Títol",
        "type": "text",
        "required": false,
        "default": "Local WiFi Details",
        "placeholder": "WiFi de casa"
      },
      {
        "key": "qrSize",
        "label": "Mida del codi QR (píxels)",
        "type": "number",
        "required": false,
        "default": 125
      },
      {
        "key": "showNetwork",
        "label": "Mostrar nom de la xarxa",
        "type": "boolean",
        "required": false,
        "default": true
      },
      {
        "key": "showPassword",
        "label": "Mostrar contrasenya",
        "type": "boolean",
        "required": false,
        "default": true
      },
      {
        "key": "layoutVertical",
        "label": "Disposició vertical",
        "type": "boolean",
        "required": false,
        "default": true
      }
    ]
  },
  "MMM-MoonPhase": {
    "fields": [
      {
        "key": "updateInterval",
        "label": "Interval d'actualització (ms)",
        "type": "number",
        "required": false,
        "default": 3600000
      },
      {
        "key": "hemisphere",
        "label": "Hemisferi",
        "type": "select",
        "required": false,
        "default": "N",
        "options": ["N", "S"]
      },
      {
        "key": "geoCoords",
        "label": "Coordenades geogràfiques",
        "type": "text",
        "required": false,
        "placeholder": "41.3851,2.1734"
      }
    ]
  },
  "MMM-AirQuality": {
    "fields": [
      {
        "key": "location",
